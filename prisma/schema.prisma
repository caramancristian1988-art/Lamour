generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Everything below is EXAMPLE domain modeling for a product/service catalog
// (Category/Product/Review/Faq/BlogPost/Service*/Project/ContactMessage/PopupEvent/Settings).
// Keep the shape if it fits, otherwise replace with your own models —
// User/Session are the only models the auth system in lib/auth.ts depends on.

model Category {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String    @unique
  description String?
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  slug        String   @unique
  description String?
  price       Float
  oldPrice    Float?
  image       String?
  images      String[] @default([])
  packageQuantity String?
  brand       String?
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  badge       String?
  availability String  @default("În stoc")
  popupEnabled Boolean @default(false)
  installmentsEnabled Boolean @default(true)
  specifications ProductSpec[]
  categoryId  String   @db.ObjectId
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
}

type ProductSpec {
  label String
  value String
}

type ListingCharacteristic {
  label String
  value String
}

model FurnitureListing {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  type        String
  title       String
  priceLabel  String
  price       Float?
  material    String
  leadTime    String?
  image       String?
  description String?
  characteristics ListingCharacteristic[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model SpaceListing {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  type        String
  title       String
  priceLabel  String
  price       Float?
  area        Float
  location    String
  image       String?
  description String?
  characteristics ListingCharacteristic[]
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Review {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String?
  rating    Float
  text      String
  pros      String?
  cons      String?
  image     String?
  product   String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())
}

model Faq {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Banner {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  image        String
  alt          String
  title        String?
  subtitle     String?
  ctaLabel     String?
  ctaPositionX Float    @default(15)
  ctaPositionY Float    @default(85)
  link         String?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
}

model BlogPost {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String   @unique
  description String
  image       String?
  content     String?
  category    String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model ProductFaq {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String   @db.ObjectId
  question  String
  answer    String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  name              String
  phone             String
  email             String?
  message           String?
  source            String   @default("Pagina de contact")
  read              Boolean  @default(false)
  status            String   @default("in_asteptare")
  mood              String?
  telegramMessageId Int?
  productIds        String[] @default([]) @db.ObjectId
  createdAt         DateTime @default(now())
}

model PopupEvent {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  productSlug String
  event       String
  createdAt   DateTime @default(now())
}

model Settings {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  phone       String?
  email       String?
  address     String?
  facebook    String?
  instagram   String?
  tiktok      String?
  seoTitle    String?
  seoDescription String?
  produseEnabled  Boolean @default(true)
  despreEnabled   Boolean @default(true)
  blogEnabled     Boolean @default(true)
  contactEnabled  Boolean @default(true)
  ratesEnabled    Boolean @default(true)
  installmentMonths Int @default(4)
  popupCountdownMinutes Int @default(10)
}

model User {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String    @unique
  password  String
  isAdmin   Boolean   @default(false)
  createdAt DateTime  @default(now())
  sessions  Session[]
}

model Session {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  token     String   @unique
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}
